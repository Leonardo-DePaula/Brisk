from tkinter import *
from tkinter import ttk
from tkinter import colorchooser

SEM_COR = ''  # representa "sem preenchimento" (transparente)


def inicia_figura(event):
    global figura_nova
    if tipo_figura_var.get() in ('Linha', 'Circulo', 'Retangulo', 'Oval'):
        figura_nova = (tipo_figura_var.get(), [event.x, event.y, event.x, event.y],
                        cor_atual.get(), cor_preenchimento.get())
    else:
        figura_nova = ("rabisco", [(event.x, event.y)], cor_atual.get(), SEM_COR)


def atualizar_figura(event):
    global figura_nova
    if figura_nova:
        if figura_nova[0] in ('Linha', 'Circulo', 'Retangulo', 'Oval'):
            figura_nova[1][2] = event.x
            figura_nova[1][3] = event.y
        else:
            figura_nova[1].append((event.x, event.y))
        desenhar()


def incluir_figura(event):
    global figura_nova
    if figura_nova:
        figuras.append(figura_nova)
        figura_nova = None
        desenhar()


def desenhar():
    canvas.delete("all")
    todas = figuras + ([figura_nova] if figura_nova else [])
    for figura in todas:
        tipo, coords, cor, preenchimento = figura
        if tipo == 'Linha':
            canvas.create_line(*coords, fill=cor)
        elif tipo in ('Circulo', 'Oval'):
            canvas.create_oval(*coords, outline=cor, fill=preenchimento)
        elif tipo == 'Retangulo':
            canvas.create_rectangle(*coords, outline=cor, fill=preenchimento)
        else:  # rabisco
            pontos = [c for ponto in coords for c in ponto]
            if len(pontos) >= 4:
                canvas.create_line(*pontos, fill=cor)


def escolher_cor():
    cor = colorchooser.askcolor(color=cor_atual.get(), title="Escolha a cor da figura")
    if cor[1] is not None:
        cor_atual.set(cor[1])
        amostra_cor.config(bg=cor[1])


def preencher_cor_figura():
    cor_inicial = cor_preenchimento.get() or 'white'
    cor = colorchooser.askcolor(color=cor_inicial, title="Escolha a cor de preenchimento")
    if cor[1] is not None:
        cor_preenchimento.set(cor[1])
        amostra_cor_preenchimento.config(bg=cor[1])
    # se cancelar, não mexe na cor de preenchimento atual


def remover_preenchimento():
    cor_preenchimento.set(SEM_COR)
    amostra_cor_preenchimento.config(bg=canvas['bg'])


figuras = []
root = Tk()

canvas = Canvas(root, bg='white', width=600, height=600)
canvas.pack()

tipo_figura_var = StringVar()
tipo_figura_var.set('Linha')

cor_atual = StringVar()
cor_atual.set('black')

barra_controles = Frame(root)
barra_controles.pack()

tipo_figura_menu = OptionMenu(barra_controles, tipo_figura_var, 'Linha', 'Circulo', 'Retangulo', 'Oval')
tipo_figura_menu.pack(side=LEFT)

botao_cor = Button(barra_controles, text="Escolher Cor", command=escolher_cor)
botao_cor.pack(side=LEFT, padx=5)

amostra_cor = Label(barra_controles, text="  ", bg=cor_atual.get(), relief=SUNKEN, width=4)
amostra_cor.pack(side=LEFT)

cor_preenchimento = StringVar()
cor_preenchimento.set(SEM_COR)

botao_cor_preenchimento = Button(barra_controles, text="Escolher Cor de Preenchimento", command=preencher_cor_figura)
botao_cor_preenchimento.pack(side=LEFT, padx=5)

botao_sem_preenchimento = Button(barra_controles, text="Sem Preenchimento", command=remover_preenchimento)
botao_sem_preenchimento.pack(side=LEFT, padx=5)

preechimento = Label(barra_controles, text="Preenchimento")
preechimento.pack(side=LEFT)

amostra_cor_preenchimento = Label(barra_controles, text="  ", bg=canvas['bg'], relief=SUNKEN, width=4)
amostra_cor_preenchimento.pack(side=LEFT)

figura_nova = None
canvas.bind('<ButtonPress-1>', inicia_figura)
canvas.bind('<B1-Motion>', atualizar_figura)
canvas.bind('<ButtonRelease-1>', incluir_figura)

root.mainloop()
